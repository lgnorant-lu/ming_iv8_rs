# ============================================================================
# iv8-rs .gitignore
# ============================================================================

# ── Rust ────────────────────────────────────────────────────────────────────
target/
Cargo.lock.bak
**/*.rs.bk
*.pdb

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.dylib
*.egg-info/
*.egg
build/
dist/
.eggs/
develop-eggs/
.installed.cfg

# ── Python virtual environments ─────────────────────────────────────────────
.venv/
.venv-probe/
venv/
env/
ENV/
.python-version

# ── uv lock files ───────────────────────────────────────────────────────────
# uv.lock kept (lockfile should be committed for reproducibility)

# ── maturin / wheels ────────────────────────────────────────────────────────
wheels/
*.whl

# ── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.iml

# ── Kiro IDE / Spec workflow（项目独属，不提交）────────────────────────────
.kiro/
.ace-tool/

# ── Test / Coverage / Cache ─────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/
*.cover
.cache/
coverage.xml
nosetests.xml

# ── Benchmark / Profiling ───────────────────────────────────────────────────
flamegraph.svg
perf.data*
*.prof

# ── Third-party reference data (local only) ──────────────────────────────────
_ref/
docs/research/iv8-*.json
!docs/research/iv8-defaults.json
docs/research/iv8-*.txt
docs/research/d-[1234]-iv8-*.md

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temporary / Scratch ─────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
scratch/
tmp/

# ── iv8 reference (参考代码，不提交)─────────────────────────────────────────
tests/iv8-ref/

# ── Documentation build outputs ─────────────────────────────────────────────
docs/_build/
docs/.doctrees/
site/

# ── Local planning / release notes (不进 release 面) ─────────────────────────
docs/TODO-v0.5-enhancements.md

# ── OS-specific ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Analysis scripts (local tooling, not core) ────────────────────────────────
scripts/ghidra_*.py
scripts/disasm_*.py
scripts/find_func_rvas.py
scripts/debug_rel.py
docs/research/disasm/
*.asm
*.gpr
*.gbf
*.rep/

# ── Local scripts (non-core) ─────────────────────────────────────────────────
scripts/probe-iv8*.py
scripts/probe_iv8*.py
tests/probe_*.py

# ── Activate scripts (本地环境)──────────────────────────────────────────────
scripts/activate-env.ps1

# ── 本地测试探测产物 ─────────────────────────────────────────────────────
tests/probe_results.json
tests/_*.py
scripts/_*.py
scripts/diag*.py

# -- 前端产物 -------------------------
node_modules/*
temp/